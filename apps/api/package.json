{
  "name": "@ryba/api",
  "version": "0.1.0",
  "private": true,
  "description": "Minimal NestJS API for Ryba technical research stage.",
  "main": "dist/main.js",
  "types": "dist/main.d.ts",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.5",
    "@nestjs/core": "^10.4.5",
    "@nestjs/platform-express": "^10.4.5",
    "@ryba/schemas": "workspace:*",
    "@ryba/types": "workspace:*",
    "dotenv": "^16.4.5",
    "pg": "^8.13.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@types/pg": "^8.15.5",
    "@types/node": "^22.13.10",
    "tsx": "^4.19.4",
    "typescript": "^5.8.2"
  }
}
