{
  "name": "@ryba/collab",
  "private": true,
  "version": "0.1.0",
  "description": "Ryba collaboration prototype server using Hocuspocus and Yjs.",
  "type": "module",
  "engines": {
    "node": ">=22 <23"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@hocuspocus/server": "^3.2.3",
    "yjs": "^13.6.13"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "tsx": "^4.7.0",
    "typescript": "^5.8.3"
  }
}
